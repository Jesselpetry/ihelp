# GitHub OAuth App credentials for the "push to GitHub" feature.
# Create one at https://github.com/settings/developers (New OAuth App) with:
#   Authorization callback URL: <your-app-url>/api/github/callback
#   (add http://localhost:3000/api/github/callback for local development)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Public base URL used to build the OAuth redirect_uri. Must match the
# callback URL registered on the OAuth App. Optional in local dev (falls back
# to the request origin), required behind a proxy / in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
